{
  "compilerOptions": {
    "strict": false,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM"],
    "jsx": "preserve",
    "jsxImportSource": "@nativescript-dom/solidjs-types",
    "rootDirs": [".", "../.."],
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"],
      "@/*": ["src/*"],
      "@demo/shared": ["../../tools/demo/index.ts"],
      "@triniwiz/nativescript-masonkit": ["../../packages/nativescript-masonkit/index.d.ts", "../../packages/nativescript-masonkit/typings/android.d.ts", "../../packages/nativescript-masonkit/typings/objc!Mason.d.ts", "../../packages/nativescript-masonkit/typings/objc!ObjectiveC.d.ts"],
      "@triniwiz/*": ["../../packages/*"]
    },
    "noEmit": true,
    "allowJs": true,
    "typeRoots": ["../../packages/nativescript-masonkit/typings/"],
    "types": ["node", "@nativescript-dom/core-types", "@nativescript-dom/solidjs-types"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "noEmitHelpers": true,
    "importHelpers": true
  },
  "include": ["src", "references.d.ts"],
  "exclude": ["node_modules", "platforms", "**/*.test.ts", "**/*.spec.ts"]
}
